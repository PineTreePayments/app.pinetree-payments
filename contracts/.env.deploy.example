# Copy this file to .env.deploy (git-ignored) and fill in your values

# Private key of the wallet that will deploy the contract (needs ~$5 of Base ETH for gas)
# Export from MetaMask: Account Details → Export Private Key
# DO NOT prefix with 0x — just the raw 64-char hex key
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Base mainnet RPC (default works, or use your Alchemy/Infura endpoint)
BASE_RPC_URL=https://mainnet.base.org
