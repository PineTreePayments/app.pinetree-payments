{
  "name": "@pinetreepayments/react",
  "version": "0.1.0",
  "description": "Official PineTree React SDK — browser checkout components and hooks.",
  "keywords": ["pinetree", "payments", "react", "checkout", "crypto", "blockchain", "browser", "ui", "components"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pinetree-payments/pinetree-payments.git",
    "directory": "packages/pinetree-react"
  },
  "homepage": "https://app.pinetree-payments.com",
  "bugs": { "url": "https://github.com/pinetree-payments/pinetree-payments/issues" },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@pinetreepayments/js": "^0.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
