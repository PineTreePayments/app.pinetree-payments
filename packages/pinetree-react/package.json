{
  "name": "@pinetree/react",
  "version": "0.1.0",
  "private": true,
  "description": "Private React bindings for the PineTree browser SDK.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@pinetree/js": "file:../pinetree-js"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
