# PineTree Wallet Dynamic External JWT / BYOA placeholders.
# Generate real values with:
# npm run dynamic:jwt:generate

NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=<from Dynamic dashboard>
NEXT_PUBLIC_PINETREE_DYNAMIC_AUTH_MODE=external_jwt
NEXT_PUBLIC_PINETREE_DYNAMIC_EMAIL_FALLBACK=false

# Server-only bearer token for authenticated maintenance endpoints.
CRON_SECRET=<generate a strong random server-only secret>

DYNAMIC_EXTERNAL_JWT_ENABLED=true
DYNAMIC_EXTERNAL_JWT_ISSUER=https://app.pinetree-payments.com
# Audience is NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID. Set an override only if
# Dynamic support explicitly requires a different value.
DYNAMIC_EXTERNAL_JWT_AUDIENCE_OVERRIDE=
DYNAMIC_EXTERNAL_JWT_KID=<generated kid>
DYNAMIC_EXTERNAL_JWT_SIGNING_KEY_B64=<server-only generated base64 signing key>

# Speed Custom Connect / managed Lightning
SPEED_API_KEY=<Speed platform API key>
SPEED_WEBHOOK_SECRET=<Speed account-level webhook secret>
SPEED_CONNECT_WEBHOOK_SECRET=<Speed connected-account webhook secret>
SPEED_CONNECT_ENABLED=false
SPEED_API_BASE_URL=https://api.tryspeed.com
SPEED_ENVIRONMENT=test
PINE_TREE_LIGHTNING_PROVIDER=speed
PINE_TREE_LIGHTNING_SETTLEMENT_MODE=speed_merchant_account

# Unified Speed Custom Connect password. Server-only, never returned to the
# browser, logged, or stored in Supabase. Required when SPEED_CONNECT_ENABLED
# is true. See docs/environment/speed-credentials-env-checklist.md.
SPEED_CONNECTED_ACCOUNT_PASSWORD=<server-only Speed account password>
# Legacy admin recovery only. Preserve the original 64-char hex key anywhere
# historical merchant_speed_credentials rows must remain decryptable.
SPEED_CREDENTIAL_ENCRYPTION_KEY=

# Automatic Lightning sweep (Speed Custom Connect balance -> PineTree Wallet
# BOLT11 invoice via Speed Instant Send). Server-only - never prefix with
# NEXT_PUBLIC_. See docs/environment/lightning-sweep-env-checklist.md.
# Must be exactly "true" to allow ANY outbound Speed Instant Send call.
SPEED_LIGHTNING_SWEEP_ENABLED=false
# Speed's confirmed endpoints are /balances, /balance-transactions, and
# /send. Merchant calls use the server-resolved acct_ identifier in the
# canonical `speed-account` header; no endpoint/header override is accepted.
SPEED_SWEEP_MIN_SATS=1
SPEED_SWEEP_FEE_RESERVE_SATS=0
SPEED_SWEEP_MAX_ATTEMPTS=5
SPEED_SWEEP_RETRY_BASE_SECONDS=30

# Connected-account balances, transaction sync, and user-triggered Lightning
# withdrawals are active whenever Speed and Connect are configured. Speed
# does not expose AutoPayout or AutoSwap APIs; there are intentionally no
# feature flags that can claim those capabilities are available.
