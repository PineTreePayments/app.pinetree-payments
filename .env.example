# PineTree Wallet Dynamic External JWT / BYOA placeholders.
# Generate real values with:
# npm run dynamic:jwt:generate

NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=<from Dynamic dashboard>
NEXT_PUBLIC_PINETREE_DYNAMIC_AUTH_MODE=external_jwt
NEXT_PUBLIC_PINETREE_DYNAMIC_EMAIL_FALLBACK=false

DYNAMIC_EXTERNAL_JWT_ENABLED=true
DYNAMIC_EXTERNAL_JWT_ISSUER=https://app.pinetree-payments.com
DYNAMIC_EXTERNAL_JWT_AUDIENCE=dynamic
DYNAMIC_EXTERNAL_JWT_KID=<generated kid>
DYNAMIC_EXTERNAL_JWT_SIGNING_KEY_B64=<server-only generated base64 signing key>

# Speed Custom Connect / managed Lightning
SPEED_API_KEY=<Speed platform API key>
SPEED_WEBHOOK_SECRET=<Speed account-level webhook secret>
SPEED_CONNECT_WEBHOOK_SECRET=<Speed connected-account webhook secret>
SPEED_CONNECT_ENABLED=false
SPEED_API_BASE_URL=https://api.tryspeed.com
SPEED_ENVIRONMENT=test
PINE_TREE_LIGHTNING_PROVIDER=speed
PINE_TREE_LIGHTNING_SETTLEMENT_MODE=speed_merchant_account
