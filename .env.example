# PineTree Wallet Dynamic External JWT / BYOA placeholders.
# Generate real values with:
# npm run dynamic:jwt:generate

NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=<from Dynamic dashboard>
NEXT_PUBLIC_PINETREE_DYNAMIC_AUTH_MODE=external_jwt
NEXT_PUBLIC_PINETREE_DYNAMIC_EMAIL_FALLBACK=false

# Server-only bearer token for authenticated maintenance endpoints.
CRON_SECRET=<generate a strong random server-only secret>

DYNAMIC_EXTERNAL_JWT_ENABLED=true
DYNAMIC_EXTERNAL_JWT_ISSUER=https://app.pinetree-payments.com
DYNAMIC_EXTERNAL_JWT_AUDIENCE=dynamic
DYNAMIC_EXTERNAL_JWT_KID=<generated kid>
DYNAMIC_EXTERNAL_JWT_SIGNING_KEY_B64=<server-only generated base64 signing key>

# Speed Custom Connect / managed Lightning
SPEED_API_KEY=<Speed platform API key>
SPEED_WEBHOOK_SECRET=<Speed account-level webhook secret>
SPEED_CONNECT_WEBHOOK_SECRET=<Speed connected-account webhook secret>
SPEED_CONNECT_ENABLED=false
SPEED_API_BASE_URL=https://api.tryspeed.com
SPEED_ENVIRONMENT=test
PINE_TREE_LIGHTNING_PROVIDER=speed
PINE_TREE_LIGHTNING_SETTLEMENT_MODE=speed_merchant_account

# Speed Custom Connect credential retention (server-only secrets - never
# prefix with NEXT_PUBLIC_, never returned to the browser or any merchant
# API). See docs/environment/speed-credentials-env-checklist.md.
# One shared password for every non-production Speed Custom Connect account.
SPEED_TEST_ACCOUNT_PASSWORD=<server-only shared test-account password>
# AES-256-GCM key (64 hex chars / 32 bytes) used to encrypt retained Speed
# account passwords before database storage. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SPEED_CREDENTIAL_ENCRYPTION_KEY=<server-only 64-char hex encryption key>

# Automatic Lightning sweep (Speed Custom Connect balance -> PineTree Wallet
# BOLT11 invoice via Speed Instant Send). Server-only - never prefix with
# NEXT_PUBLIC_. See docs/environment/lightning-sweep-env-checklist.md.
# Must be exactly "true" to allow ANY outbound Speed Instant Send call.
SPEED_LIGHTNING_SWEEP_ENABLED=false
# PLACEHOLDERS - Speed has not yet supplied the exact Instant Send endpoint,
# HTTP method, or request/response schema. Do not set these to a guessed
# URL; leaving them empty is the correct state until Speed's contract is
# confirmed and providers/lightning/speedInstantSend.ts is updated to match.
SPEED_INSTANT_SEND_ENDPOINT=
SPEED_CONNECTED_BALANCE_ENDPOINT=
# Confirms which stored identifier is valid for the X-Speed-Account header
# (e.g. "ca_" or "acct_") - set only once Speed confirms the format. See
# providers/lightning/speedHeaderAccountResolver.ts.
SPEED_HEADER_ACCOUNT_ID_PREFIX=
SPEED_SWEEP_MIN_SATS=1
SPEED_SWEEP_FEE_RESERVE_SATS=0
SPEED_SWEEP_MAX_ATTEMPTS=5
SPEED_SWEEP_RETRY_BASE_SECONDS=30

# Speed Custom Connect wallet management (merchant-facing balances,
# activity, withdrawals, payouts, swaps). See
# providers/lightning/speedWalletCapabilities.ts. As of 2026-07-15, Speed's
# official public API docs (apidocs.tryspeed.com) do not document ANY
# connected-account scoping mechanism for /balances, /balance-transactions,
# /withdraw-requests, /send, or /balances/swap - so these must all stay
# "false"/empty. Do not set SPEED_WALLET_ACCOUNT_SCOPING_CONFIRMED=true or
# any of the per-capability flags below to "true" until Speed explicitly
# confirms the scoping contract for that specific endpoint. Flipping these
# flags alone will NOT enable a live call - see the unconditional
# requireContractConfirmed() chokepoint in
# providers/lightning/speedWalletManagement.ts.
SPEED_WALLET_ACCOUNT_SCOPING_CONFIRMED=false
SPEED_WALLET_BALANCES_ENABLED=false
SPEED_WALLET_TRANSACTIONS_ENABLED=false
SPEED_WALLET_TRANSFERS_ENABLED=false
SPEED_WALLET_WITHDRAWALS_ENABLED=false
SPEED_WALLET_PAYOUTS_ENABLED=false
SPEED_WALLET_PAYOUT_STATUS_ENABLED=false
SPEED_WALLET_MANUAL_SWAP_ENABLED=false
SPEED_WALLET_AUTOMATIC_PAYOUTS_ENABLED=false
SPEED_WALLET_AUTOMATIC_SWAP_ENABLED=false
