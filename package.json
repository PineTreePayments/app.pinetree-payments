{
  "name": "pinetree-pos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:env": "node scripts/check-environment.mjs",
    "check:env:strict": "node scripts/check-environment.mjs --strict",
    "dynamic:jwt:generate": "node scripts/generate-dynamic-external-jwt-keys.mjs",
    "dynamic:jwt:test": "node scripts/test-dynamic-external-jwt.mjs",
    "smoke:staging-routes": "node scripts/smoke-staging-routes.mjs",
    "smoke:wallet-approval": "node scripts/smoke-wallet-approval.mjs",
    "smoke:checkout-api": "node scripts/smoke-checkout-api.mjs",
    "release-candidate": "node scripts/release-candidate.mjs",
    "release-candidate:dry-run": "node scripts/release-candidate.mjs --dry-run",
    "sdk:release-candidate": "npm run release-candidate --workspace packages/pinetree-node",
    "package:woocommerce": "node scripts/package-woocommerce-plugin.mjs",
    "validate:woocommerce-package": "node scripts/package-woocommerce-plugin.mjs --dry-run && node scripts/validate-woocommerce-plugin.mjs"
  },
  "dependencies": {
    "@dynamic-labs/bitcoin": "^4.90.0",
    "@dynamic-labs/ethereum": "^4.90.0",
    "@dynamic-labs/sdk-react-core": "^4.90.0",
    "@dynamic-labs/solana": "^4.90.0",
    "@dynamic-labs/spark": "^4.90.0",
    "@meshconnect/web-link-sdk": "^3.9.8",
    "@noble/curves": "^2.2.0",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.8",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-query": "^5.100.1",
    "@walletconnect/ethereum-provider": "^2.23.8",
    "@walletconnect/universal-provider": "^2.23.8",
    "bitcoinjs-lib": "^6.1.5",
    "coinbase-commerce-node": "^1.0.4",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.0",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0",
    "viem": "^2.48.4",
    "wagmi": "^3.6.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ethers": "^6.16.0",
    "playwright": "^1.60.0",
    "solc": "^0.8.34",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
